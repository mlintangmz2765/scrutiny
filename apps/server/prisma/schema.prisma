generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Append-only — there is deliberately no update/delete path for audit rows.
model AuditLog {
  id           String   @id @default(cuid())
  userId       String?
  action       String // CREATE | UPDATE | DELETE | STATUS | LOGIN | LOGIN_FAILED
  entityType   String
  entityId     String
  engagementId String?
  changes      String? // JSON: { field: [old, new] }
  createdAt    DateTime @default(now())

  @@index([engagementId, createdAt])
  @@index([createdAt])
}

model Client {
  id                 String   @id @default(cuid())
  name               String
  registrationNumber String?
  industry           String?
  contactName        String?
  contactEmail       String?
  notes              String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  engagements Engagement[]
}

model Engagement {
  id                 String             @id @default(cuid())
  clientId           String
  client             Client             @relation(fields: [clientId], references: [id])
  name               String
  periodStart        DateTime
  periodEnd          DateTime
  currencyCode       String             @default("USD")
  minorUnitsPerMajor Int                @default(100)
  // PLANNING | FIELDWORK | REVIEW | COMPLETION | ARCHIVED (DOMAIN.md §1)
  status             String             @default("PLANNING")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  members            EngagementMember[]

  @@index([clientId])
}

model EngagementMember {
  id           String     @id @default(cuid())
  engagementId String
  engagement   Engagement @relation(fields: [engagementId], references: [id])
  userId       String
  user         User       @relation(fields: [userId], references: [id])
  createdAt    DateTime   @default(now())

  @@unique([engagementId, userId])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  // ADMIN | PARTNER | MANAGER | STAFF — SQLite has no enums; validated by
  // userRoleSchema in @scrutiny/shared (see docs/DECISIONS.md).
  role         String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  engagementMemberships EngagementMember[]
}
