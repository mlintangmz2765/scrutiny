generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  // ADMIN | PARTNER | MANAGER | STAFF — SQLite has no enums; validated by
  // userRoleSchema in @scrutiny/shared (see docs/DECISIONS.md).
  role         String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
